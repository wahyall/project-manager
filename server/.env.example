# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/yn-project-manager

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Client URL (untuk CORS)
CLIENT_URL=http://localhost:3000

# App URL (untuk link di notifikasi)
APP_BASE_URL=http://localhost:3000

# Email (Brevo API)
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=YukNgaji Surabaya

# WhatsApp (Baileys)
WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=./auth_info
# API key for POST /api/external/whatsapp/send (no JWT). Use a long random string in production.
WHATSAPP_EXTERNAL_API_KEY=

# Google Gemini (CopilotKit AI Chat)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# Puter.js
PUTER_API_KEY=your-puter-api-key
